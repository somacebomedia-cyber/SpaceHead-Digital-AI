rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200
          && data.description is string && data.description.size() <= 1000
          && data.category is string && data.category.size() <= 100
          && data.tags is list && data.tags.size() <= 20
          && data.createdAt is number
          && data.userId is string && data.userId.size() <= 100
          && data.isPublic is bool;
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() <= 200
          && data.slug is string && data.slug.size() <= 200
          && data.summary is string && data.summary.size() <= 1000
          && data.content is string && data.content.size() <= 10000
          && data.category is string && data.category.size() <= 100
          && data.tags is list && data.tags.size() <= 20
          && data.createdAt is number
          && data.updatedAt is number
          && data.userId is string && data.userId.size() <= 100
          && data.authorName is string && data.authorName.size() <= 100
          && data.isPublished is bool;
    }

    match /projects/{projectId} {
      allow get: if isValidId(projectId);
      allow list: if true;
      allow create: if isValidId(projectId) && isSignedIn() && isValidProject(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isValidId(projectId) && isSignedIn() && isValidProject(incoming()) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
      allow delete: if isValidId(projectId) && isSignedIn() && existing().userId == request.auth.uid;
    }

    match /blogs/{blogId} {
      allow get: if isValidId(blogId);
      allow list: if true;
      allow create: if isValidId(blogId) && isSignedIn() && isValidBlogPost(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isValidId(blogId) && isSignedIn() && isValidBlogPost(incoming()) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
      allow delete: if isValidId(blogId) && isSignedIn() && existing().userId == request.auth.uid;
    }

    match /settings/{settingsId} {
      allow get: if isValidId(settingsId) && isSignedIn();
      allow write: if isValidId(settingsId) && isSignedIn();
    }
  }
}
